# API server
API_HOST=0.0.0.0
API_PORT=8000
ARTIFACTS_DIR=artifacts
MAX_UPLOAD_BYTES=20971520

# Mock modes (offline lab — no Azure credentials required)
USE_MOCK_EXTRACTION=true
USE_MOCK_KNOWLEDGE=true

# Azure Content Understanding (set when USE_MOCK_EXTRACTION=false)
# CU_ENDPOINT=https://<resource>.services.ai.azure.com
# CU_API_KEY=<from-key-vault-or-portal>
# CU_ANALYZER_ID=drawing-architecture-v1

# Foundry IQ / Azure AI Search (set when USE_MOCK_KNOWLEDGE=false)
# SEARCH_ENDPOINT=https://<search>.search.windows.net
# SEARCH_API_KEY=<from-key-vault-or-portal>
# KNOWLEDGE_BASE_NAME=ncc-compliance-kb

# Rule packs
DEFAULT_RULE_PACK=ncc-accessibility-v1
MIN_EXTRACTION_CONFIDENCE=0.75
